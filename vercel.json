{
  "rewrites": [
    { "source": "/compass", "destination": "/compass.html" },
    { "source": "/invite/:code", "destination": "/invite.html" },
    { "source": "/invite", "destination": "/invite.html" },
    { "source": "/ai-daily-planner", "destination": "/ai-daily-planner.html" },
    { "source": "/1-3-5-productivity-method", "destination": "/1-3-5-productivity-method.html" },
    { "source": "/freedom-number-calculator", "destination": "/freedom-number-calculator.html" },
    { "source": "/find-your-direction", "destination": "/find-your-direction.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
